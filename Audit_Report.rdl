        </Field>
        <Field Name="Asset_LoggedOn">
          <DataField>Asset.LoggedOn</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="Purch_PO">
          <DataField>Purch.PO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Purch_ORD">
          <DataField>Purch.ORD</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ReceivingID">
          <DataField>ReceivingID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
