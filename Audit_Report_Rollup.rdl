  <DataSets>
    <DataSet Name="StartDate">
      <Query>
        <DataSourceName>ds_GP</DataSourceName>
        <CommandText>-- 2021-01-05
--select DATE = CAST(FORMAT(GETDATE(),'yyyy-01-01') AS DATE)
select DATE = CAST(FORMAT(dateadd(month,-13,GETDATE()),'yyyy-MM-01') AS DATE) </CommandText>
      </Query>
      <Fields>
        <Field Name="DATE">
          <DataField>DATE</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_20210105">
      <Query>
        <DataSourceName>ds_GP</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20210105 rollup

--DECLARE @StartDate DATE =  CAST(FORMAT(dateadd(year,-2,GETDATE()),'yyyy-MM-01') AS DATE)  --CAST(FORMAT(GETDATE(),'yyyy-01-01') AS DATE)
--PRINT @StartDate

;
WITH
cte_rpt
AS
(
SELECT
     CASE (SELECT ReceivingLogType FROM dbo.TRI_II_IM_ReceivingLog_Master WHERE ReceivingID=M.ReceivingID)
            WHEN 1 THEN 'BS'
            WHEN 2 THEN 'OL'
            ELSE 'ERROR'
            END [Type]
     ,(SELECT ReceivedFrom FROM dbo.TRI_II_IM_ReceivingLog_Master WHERE ReceivingID=M.ReceivingID) [ReceivedFrom]
     ,(SELECT CreatedUser FROM dbo.TRI_II_IM_ReceivingLog_Master WHERE ReceivingID=M.ReceivingID) [Rec.LoggedBy]
     ,(SELECT IICReference FROM dbo.TRI_II_IM_ReceivingLog_Master WHERE ReceivingID=M.ReceivingID) [IICReference]
     ,LTRIM(RTRIM(S.SerialNumber)) [SerialNumber]
     ,(SELECT EquipmentCategoryValue FROM dbo.TRI_II_EquipmentCategory_Master INC WHERE INC.EquipmentCategoryID=S.EquipmentCategoryID)
     +'_'+(SELECT ManufacturerValue FROM dbo.TRI_II_Manufacturer_Master INC WHERE INC.ManufacturerID=S.ManufacturerID)
     +'_'+(SELECT PartNumber FROM dbo.TRI_II_PartNumber_Master INC WHERE INC.PartNumberID=S.PartNumberID)
     + (CASE WHEN S.FormFactorID=0 THEN '' ELSE '_'+(SELECT FormFactor FROM dbo.TRI_II_FormFactor_Master INC WHERE INC.FormFactorID=S.FormFactorID) END) [Rec.ItemNumber]
     ,CONVERT(DATE,(SELECT DockDate FROM dbo.TRI_II_IM_ReceivingLog_Master WHERE ReceivingID=M.ReceivingID)) [Rec.DockDate]
     ,CONVERT(DATE,(SELECT CreatedDateTime FROM dbo.TRI_II_IM_ReceivingLog_Master WHERE ReceivingID=M.ReceivingID)) [Rec.LoggedOn]
     ,CONVERT(DATE,S.CreatedDateTime) [Asset.LoggedOn]
     ,S.MatchedPONumber [Purch.PO]
     ,S.MatchedPOORD [Purch.ORD]
	 ,LTRIM(RTRIM(M.ReceivingID)) [ReceivingID]
FROM TRI_II_IM_AssetLog_S_Detail (NOLOCK) S 
INNER JOIN dbo.TRI_II_IM_AssetLog_Master (NOLOCK) M
    ON M.AssetLogID=S.AssetLogID
LEFT JOIN	
	(     
	SELECT atd.*
	FROM TRI_II_IM_Audit_Transaction_Details (NOLOCK) atd
	INNER JOIN TRI_II_IM_Audit_TransactionSessions (NOLOCK) ats
		ON atd.SessionID = ats.SessionID
		AND atd.SessionSequence = ats.SessionSequence
		AND ats.AuditComplete = 1
	) A 
	ON A.SerialNumber=S.SerialNumber
LEFT JOIN  
	(      
	SELECT PONUMBER, ORD 
	FROM POP10110 (NOLOCK) popOpen
    UNION ALL
    SELECT PONUMBER, ORD 
	FROM POP30110 (NOLOCK) popClosed
	) pop
    ON POP.PONUMBER=S.MatchedPONumber 
	AND POP.ORD=S.MatchedPOORD 
WHERE (A.SessionSequence IS NULL) 
	AND s.SerialNumber NOT IN (SELECT SERLNMBR FROM IV00200) 
	AND s.SerialNumber NOT IN (SELECT SERLTNUM FROM SOP10201 WHERE SOPTYPE=3 AND POSTED=1) 
	AND s.SerialNumber NOT IN (SELECT SERLTNUM FROM IV30400) 
	AND s.SerialNumber NOT IN ('HSP91D1','CN0F532H7444389I497S','CN0F532H7444389FB33S','CN0G433H7161886LAUGLA00','CN0G433H7161886LAUHLA00','CN0G433H7161886PB85LA00','CN0G434H7161887MGASHA00','CN0G434H7161886KRF34A00','8SCVBG1')
)
--------------------------
-- test code
--SELECT * FROM cte_rpt
--------------------------
,
cte_out
AS
(
SELECT 
      r.[Type]
     ,r.ReceivedFrom
     ,r.[Rec.LoggedBy]
     ,r.IICReference
     ,r.SerialNumber
     ,r.[Rec.ItemNumber]
     ,r.[Rec.DockDate]
     ,r.[Rec.LoggedOn]
     ,r.[Asset.LoggedOn]
     ,r.[Purch.PO]
     ,r.[Purch.ORD]
	 ,r.ReceivingID
FROM cte_rpt r
WHERE r.[Asset.LoggedOn] &gt;= @StartDate --'2019-01-01'
)
-----------------------------------------
-- test code
--SELECT * FROM cte_out
-----------------------------------------
-- 20201106
,
cte_orig
AS
(
SELECT 
	 LEFT([Rec.ItemNumber],3) [Category]
	 ,cte_out.Type
	,[Asset.LoggedOn] [Date]
	-----------------------------------------
	-- test code
	--,MF = DATEPART(weekday,[Asset.LoggedOn])
	-----------------------------------------
    ,[Rec.ItemNumber] ItemNumber
	,COUNT(SerialNumber) Qty
----------------------------------------------------------------------------------------
-- 20191001 does not count weekends
	--,CASE 
	--	WHEN CAST(DATEDIFF(DAY,[Asset.LoggedOn],GETDATE()) AS INT)  &gt; 10 THEN 'Red'
	--	WHEN CAST(DATEDIFF(DAY,[Asset.LoggedOn],GETDATE()) AS INT)  &gt; 6 THEN 'Yellow'
	--	ELSE ''
	--	END Fill
-----------------------------------------------------------------------------------------
-- 20201003 
	--,CASE
	--	WHEN [dbo].[fnWorkDays]([Asset.LoggedOn],Getdate(),0,0,0) &gt; 10 THEN 'Red'
	--	WHEN [dbo].[fnWorkDays]([Asset.LoggedOn],Getdate(),0,0,0) &gt; 6 THEN 'Yellow'
	--	ELSE ''
	--	END Fill
	,CASE
		WHEN [dbo].[fnWorkDays]([Asset.LoggedOn],Getdate(),0,0,0) &gt; 15 THEN 'Red'
		WHEN [dbo].[fnWorkDays]([Asset.LoggedOn],Getdate(),0,0,0) &gt; 10 THEN 'Yellow'
		ELSE ''
		END Fill
------------------------------------------------------------------------------------------
FROM 
	cte_out
--------------------------------------------------------
-- 20201028
--WHERE DATEPART(weekday,[Asset.LoggedOn]) BETWEEN 2 AND 6 -- Mon=2 - Fri=6
--------------------------------------------------------
GROUP BY 
	  LEFT([Rec.ItemNumber],3)
	 ,[Type]
	,[Asset.LoggedOn]
    ,[Rec.ItemNumber]
--ORDER BY
--	  LEFT([Rec.ItemNumber],3)
--	 ,[Type]
--	 ,[Asset.LoggedOn] DESC
--	 ,[Rec.ItemNumber] ASC
 
 --SELECT DATEPART(weekday,'2020-11-01')
 )
 ,
 cte_BS
 AS 
	 (
	 SELECT 
		ROW_NUMBER() OVER(PARTITION BY cte_orig.Category ORDER BY Category,Date ASC) [Row],
		Category ,
		[Type] ,
		[Date] ,
		ItemNumber ,
		Qty ,
		Fill 
	FROM cte_orig WHERE [Type]='BS'
	)
,
cte_OL
AS
	(
	 SELECT 
		ROW_NUMBER() OVER(PARTITION BY cte_orig.Category ORDER BY Category,Date ASC) [Row],
		Category ,
		[Type] ,
		[Date] ,
		ItemNumber ,
		Qty ,
		Fill 
	FROM cte_orig WHERE [Type]='OL'
	)
,
cte_flag2
AS 
	(
	SELECT 
		flag = 2,
		(ISNULL(cte_BS.Row,cte_OL.Row)+1) Row,
		--cte_BS.Row,
		--ISNULL(cte_BS.Category,'') BS_Category,
		ISNULL(cte_BS.Category,cte_OL.Category) Category,
		ISNULL(cte_BS.Type,'') BS_Type,
		ISNULL(FORMAT(cte_BS.[Date],'MM/dd/yyyy'),'') BS_Date, 
		ISNULL(cte_BS.ItemNumber,'') BS_ItemNumber,
		ISNULL(STR(cte_BS.Qty),'') BS_Qty,
		ISNULL(cte_BS.Fill,'') BS_Fill,
		--cte_OL.Row,
		--ISNULL(cte_OL.Category,'') OL_Category,
		ISNULL(cte_OL.Type,'') OL_Type,
		ISNULL(FORMAT(cte_OL.[Date],'MM/dd/yyyy'),'') OL_Date,
		ISNULL(cte_OL.ItemNumber,'') OL_ItemNumber,
		ISNULL(STR(cte_OL.Qty),'') OL_Qty,
		ISNULL(cte_OL.Fill,'') OL_Fill
	FROM cte_BS
	FULL JOIN cte_OL	
		ON cte_BS.Row = cte_OL.Row
		AND cte_BS.Category = cte_OL.Category
	)
------------------------------------------
,
cte_flag2BS
AS 
	(
	SELECT 
		flag = 2,
		cte_BS.Row+1 Row,
		cte_BS.Category,
		ISNULL(cte_BS.Type,'') BS_Type,
		ISNULL(FORMAT(cte_BS.[Date],'MM/dd/yyyy'),'') BS_Date, 
		ISNULL(cte_BS.ItemNumber,'') BS_ItemNumber,
		ISNULL(STR(cte_BS.Qty),'') BS_Qty,
		ISNULL(cte_BS.Fill,'') BS_Fill
	FROM cte_BS
	)
------------------------------------------
-- test code
--SELECT * FROM cte_flag2BS
------------------------------------------
,
cte_flag2OL
AS 
	(
	SELECT 
		flag = 2,
		cte_OL.Row+1 Row,
		cte_OL.Category,
		ISNULL(cte_OL.Type,'') OL_Type,
		ISNULL(FORMAT(cte_OL.[Date],'MM/dd/yyyy'),'') OL_Date,
		ISNULL(cte_OL.ItemNumber,'') OL_ItemNumber,
		ISNULL(STR(cte_OL.Qty),'') OL_Qty,
		ISNULL(cte_OL.Fill,'') OL_Fill
	FROM cte_OL	
	)
--------------------------------------------
-- test code
--SELECT * FROM cte_flag2OL

------------------------------------------
	,
cte_BS_flag1
AS
	(
	SELECT 
		ROW_NUMBER() OVER(PARTITION BY Category ORDER BY Category,BS_Date ASC) [Row_flag1],
		flag=1,
		Row=1,
		Category,
		BS_Type,
		BS_Date ='',
		BS_Date AS BS_ItemNumber,
		SUM(CONVERT(INT,BS_Qty)) BS_Qty,
		Fill='Gray'
	FROM cte_flag2
	GROUP BY 
		Category,
		BS_Type,
		BS_Date
	HAVING SUM(CONVERT(INT,BS_Qty))&lt;&gt;0	
	)
,
cte_OL_flag1
AS
	(
	SELECT 
		ROW_NUMBER() OVER(PARTITION BY Category ORDER BY Category,OL_Date ASC) [Row_flag1],
		flag=1,
		Row=1,
		Category,
		OL_Type,
		OL_Date ='',
		OL_Date AS OL_ItemNumber,
		SUM(CONVERT(INT,OL_Qty)) OL_Qty,
		Fill='Gray'
	FROM cte_flag2
	GROUP BY 
		Category,
		OL_Type,
		OL_Date
	HAVING SUM(CONVERT(INT,OL_Qty))&lt;&gt;0	
	)
,
cte_flag1BS
AS
	(
	SELECT 
		bs.flag,
		bs.Row,
		bs.Category,
		ISNULL(bs.BS_Type,'') BS_Type,
		'' BS_Date,
		ISNULL(bs.BS_ItemNumber,'') BS_ItemNumber,
		ISNULL(STR(bs.BS_Qty),'') BS_Qty,
		ISNULL(bs.Fill,'') BS_Fill
	FROM cte_BS_flag1 bs

	)
----------------------------------------
-- test code
--SELECT * FROM cte_flag1BS
----------------------------------------
,
cte_flag1OL
AS
	(
	SELECT 
		ol.flag,
		ol.Row,
		ol.Category,
		ISNULL(ol.OL_Type,'') OL_Type,
		'' OL_Date,
		ISNULL(ol.OL_ItemNumber,'') OL_ItemNumber,
		ISNULL(STR(ol.OL_Qty),'') OL_Qty,
		ISNULL(ol.Fill,'') OL_Fill
	FROM cte_OL_flag1 ol

	)
-----------------------------------------
-- test code
--SELECT * FROM cte_flag1OL
-----------------------------------------
,
cte_BS_flag0
AS
	(
	SELECT 
		ROW_NUMBER() OVER(PARTITION BY Category ORDER BY Category ASC) [Row_flag0],
		flag=0,
		Row=0,
		Category,
		BS_Type,
		BS_Date ='',
		'Grand Total:' AS BS_ItemNumber,
		SUM(CONVERT(INT,BS_Qty)) BS_Qty,
		Fill='Gray'
	FROM cte_flag2
	GROUP BY 
		Category,
		BS_Type
	HAVING SUM(CONVERT(INT,BS_Qty))&lt;&gt;0
	)
,
cte_OL_flag0
AS
	(
	SELECT 
		ROW_NUMBER() OVER(PARTITION BY Category ORDER BY Category ASC) [Row_flag0],
		flag=0,
		Row=0,
		Category,
		OL_Type,
		OL_Date ='',
		'Grand Total:' AS OL_ItemNumber,
		SUM(CONVERT(INT,OL_Qty)) OL_Qty,
		Fill='Gray'
	FROM cte_flag2
	GROUP BY 
		Category,
		OL_Type
	HAVING SUM(CONVERT(INT,OL_Qty))&lt;&gt;0
	)
,
cte_flag0BS
AS
	(
	SELECT  
		bs.flag,
	    bs.Row,
		bs.Category,
		ISNULL(bs.BS_Type,'') BS_Type,
		'' BS_Date,
		ISNULL(bs.BS_ItemNumber,'') BS_ItemNumber,
		ISNULL(STR(bs.BS_Qty),'') BS_Qty,
		ISNULL(bs.Fill,'') BS_Fill
	FROM cte_BS_flag0 bs
	)
---------------------------
-- test code
--SELECT * FROM cte_flag0BS
---------------------------
,
cte_flag0OL
AS
	(
	SELECT  
		ol.flag,
	    ol.Row,
		ol.Category,
		ISNULL(ol.OL_Type,'') OL_Type,
		'' OL_Date,
		ISNULL(ol.OL_ItemNumber,'') OL_ItemNumber,
		ISNULL(STR(ol.OL_Qty),'') OL_Qty,
		ISNULL(ol.Fill,'') OL_Fill
	FROM cte_OL_flag0 ol
	)
---------------------------
,cte_flag012BS
AS
	(
	SELECT 
		b.flag,
		b.row,
		b.Category,
		b.BS_Type,
		b.BS_Date,
		b.BS_ItemNumber,
		b.BS_Qty,
		b.BS_Fill
	FROM 
		(
		SELECT 
			b0.flag,
			b0.row,
			b0.Category,
			b0.BS_Type,
			b0.BS_Date,
			b0.BS_ItemNumber,
			b0.BS_Qty,
			b0.BS_Fill
		FROM cte_flag0BS b0
		UNION 
		SELECT 
			b1.flag,
			b1.row,
			b1.Category,
			b1.BS_Type,
			b1.BS_ItemNumber BS_Date,
			b1.BS_ItemNumber,
			b1.BS_Qty,
			b1.BS_Fill
		FROM cte_flag1BS b1
		UNION 
		SELECT 
			b2.flag,
			b2.row,
			b2.Category,
			b2.BS_Type,
			b2.BS_Date,
			b2.BS_ItemNumber,
			b2.BS_Qty,
			b2.BS_Fill
		FROM cte_flag2BS b2
		) b
	--ORDER BY 
	--	b.Category,
	--	b.BS_Date,
	--	b.[Row]
	)
--------------------
-- test code
--SELECT * FROM cte_flag012BS
--------------------
,cte_flag012OL
AS
	(
	SELECT 
		o.flag,
		o.row,
		o.Category,
		o.OL_Type,
		o.OL_Date,
		o.OL_ItemNumber,
		o.OL_Qty,
		o.OL_Fill
	FROM 
		(
		SELECT 
			o0.flag,
			o0.row,
			o0.Category,
			o0.OL_Type,
			o0.OL_Date,
			o0.OL_ItemNumber,
			o0.OL_Qty,
			o0.OL_Fill
		FROM cte_flag0OL o0
		UNION 
		SELECT 
			o1.flag,
			o1.row,
			o1.Category,
			o1.OL_Type,
			o1.OL_ItemNumber OL_Date,
			o1.OL_ItemNumber,
			o1.OL_Qty,
			o1.OL_Fill
		FROM cte_flag1OL o1
		UNION 
		SELECT 
			o2.flag,
			o2.row,
			o2.Category,
			o2.OL_Type,
			o2.OL_Date,
			o2.OL_ItemNumber,
			o2.OL_Qty,
			o2.OL_Fill
		FROM cte_flag2OL o2
		) o
	)
,
cte_BS_sort
AS
	(
	SELECT TOP(SELECT COUNT(*) FROM cte_flag012BS)
		ROW_NUMBER() OVER(PARTITION BY b.Category ORDER BY b.Category/*, b.BS_Date,b.[Row]*/ ASC) ID,
		b.flag,
		b.row,
		b.Category,
		b.BS_Type,
		b.BS_Date,
		b.BS_ItemNumber,
		b.BS_Qty,
		b.BS_Fill
	FROM cte_flag012BS b
	ORDER BY 
		b.Category,
		b.BS_Date,
		b.[Row]
	)
----------------------------
-- test code
--SELECT * FROM cte_BS_sort
----------------------------
,
cte_OL_sort
AS
	(
	SELECT TOP(SELECT COUNT(*) FROM cte_flag012OL)
		ROW_NUMBER() OVER(PARTITION BY o.Category ORDER BY o.Category/*, o.OL_Date,o.[Row]*/ ASC) ID,
		o.flag,
		o.row,
		o.Category,
		o.OL_Type,
		o.OL_Date,
		o.OL_ItemNumber,
		o.OL_Qty,
		o.OL_Fill
	FROM cte_flag012OL o
	ORDER BY 
		o.Category,
		o.OL_Date,
		o.[Row]
	)
----------------------------
-- test code
--SELECT * FROM cte_OL_sort
------------------------------
SELECT
	--b.ID,
	ISNULL(b.ID,o.ID) ID,
	ISNULL(STR(b.flag),'') BS_flag,
	-----------------------------------------
	-- test code
	--b.row,
	--b.Category,
	--ISNULL(b.BS_Type,'') BS_Type,	
	-----------------------------------------
	-- 20201222
	--IIF(b.flag=0,ISNULL(b.Category,o.Category),'') Category,
	CASE 
		WHEN b.flag=0 OR o.flag=0 THEN  COALESCE(b.Category,o.Category)
		ELSE ''
		END Category,
	-----------------------------------------
	'CornflowerBlue' Category_fill,
	'White' AS Category_Color,
--------------------------------------------------
-- 20201123
	--IIF(b.flag=2,'',ISNULL(b.BS_Type,'')) BS_Type,
	IIF(b.flag IN (1,2),'',ISNULL(b.BS_Type,'')) BS_Type,
--------------------------------------------------
	CASE 
		WHEN b.flag=1 THEN 'Gray'
		WHEN b.flag=0 THEN 'CornflowerBlue'
		ELSE 'White'
		END BS_Type_fill,
	IIF(b.flag=0,'20pt','10pt') BS_Type_size,
	----------------------------------------
	-- test code
	--ISNULL(b.BS_Date,'') BS_Date,
	----------------------------------------
	CASE 
		WHEN b.flag=1 THEN ''
		ELSE ISNULL(b.BS_Date,'')
		END BS_Date,
	ISNULL(b.BS_ItemNumber,'') BS_ItemNumber,
	IIF(b.flag=0,'Right','Left') BS_ItemNumber_Horizontal,
	ISNULL(STR(b.BS_Qty),'') BS_Qty,
	CASE
		WHEN b.flag=0 THEN 'CornflowerBlue'
		ELSE ISNULL(b.BS_Fill,'') 
		END BS_Fill,
	CASE
		WHEN b.flag IN (0,1) THEN 'White'
		ELSE 'Black' 
		END BS_Color,
	ISNULL(STR(o.flag),'') OL_flag,
	----------------------------------------
	-- test code
	--o.ID,		
	--o.row,
	--o.Category,
	--ISNULL(o.OL_Type,'') OL_Type,
	-----------------------------------------------	
	-- 20201123
	--IIF(o.flag=2,'',ISNULL(o.OL_Type,'')) OL_Type,
	IIF(o.flag IN (1,2),'',ISNULL(o.OL_Type,'')) OL_Type,
	-----------------------------------------------
	CASE 
		WHEN o.flag=1 THEN 'Gray'
		WHEN o.flag=0 THEN 'CornflowerBlue'
		ELSE 'White'
		END OL_Type_fill,
	IIF(o.flag=0,'20pt','10pt') OL_Type_size,
	----------------------------------------
	-- test code
	--ISNULL(o.OL_Date,'') OL_Date,
	----------------------------------------
	CASE 
		WHEN o.flag=1 THEN ''
		ELSE ISNULL(o.OL_Date,'')
		END OL_Date,
	ISNULL(o.OL_ItemNumber,'') OL_ItemNumber,
	IIF(o.flag=0,'Right','Left') OL_ItemNumber_Horizontal,
	ISNULL(STR(o.OL_Qty),'') OL_Qty,
	CASE
		WHEN o.flag=0 THEN 'CornflowerBlue'
		ELSE ISNULL(o.OL_Fill,'') 
		END OL_Fill,
	CASE
		WHEN o.flag IN (0,1) THEN 'White'
		ELSE 'Black' 
		END OL_Color
FROM cte_BS_sort b
FULL JOIN cte_OL_sort o
	ON b.Category = o.Category
	AND b.ID =o.ID
ORDER BY
	ISNULL(b.Category,o.Category),
	ISNULL(b.ID,o.ID)</CommandText>
      </Query>
      <Fields>
        <Field Name="ID">
          <DataField>ID</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="BS_flag">
          <DataField>BS_flag</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Category">
          <DataField>Category</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Category_fill">
          <DataField>Category_fill</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Category_Color">
          <DataField>Category_Color</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BS_Type">
          <DataField>BS_Type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BS_Type_fill">
          <DataField>BS_Type_fill</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BS_Type_size">
          <DataField>BS_Type_size</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BS_Date">
          <DataField>BS_Date</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BS_ItemNumber">
          <DataField>BS_ItemNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BS_ItemNumber_Horizontal">
          <DataField>BS_ItemNumber_Horizontal</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BS_Qty">
          <DataField>BS_Qty</DataField>
          <rd:TypeName>System.String</rd:TypeName>
