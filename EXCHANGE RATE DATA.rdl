          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="TIME1">
          <DataField>TIME1</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="XCHGRATE">
