  <DataSources>
    <DataSource Name="DYNAMICS">
      <DataSourceReference>Dynamics</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>022684c5-bdcf-4e4d-acb5-075f7ed44405</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="GP">
      <Query>
        <DataSourceName>DYNAMICS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@YEAR1">
            <Value>=Parameters!YEAR1.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--DECLARE @YEAR1 INT='2024'

SELECT * FROM MC00100 A WITH (NOLOCK) WHERE A.EXGTBLID='Z-C$-AVG'
AND YEAR(A.EXCHDATE) = @YEAR1
ORDER BY A.EXCHDATE</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
