  <DataSources>
    <DataSource Name="IIC01">
      <DataSourceReference>IIC01</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>022684c5-bdcf-4e4d-acb5-075f7ed44405</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="GP">
      <Query>
        <DataSourceName>IIC01</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FROMDATE">
            <Value>=Parameters!FROMDATE.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@TODATE">
            <Value>=Parameters!TODATE.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>DECLARE @AccountIndex NVARCHAR(MAX)
SET @AccountIndex = 4755

--SELECT * FROM SEE30303

SELECT  *
FROM    ( SELECT    *
          FROM      ( SELECT   'OPEN' AS Status ,
                               [TRXDATE] ,
                               [JRNENTRY] ,
                               [ACTINDX] ,
							   [ORGNTSRC],
							   [ORMSTRID],
							   [ORDOCNUM],
							   [SOURCDOC],
                               SUM([DEBITAMT]) Dr ,
                               SUM([CRDTAMNT]) Cr
                      FROM     GL20000 WITH (NOLOCK)
                      GROUP BY [TRXDATE] ,
                               [JRNENTRY] ,
                               [ACTINDX],
							   [ORGNTSRC],
							   [ORMSTRID],
							   [ORDOCNUM],
							   [SOURCDOC]
                      UNION ALL
                      SELECT   'History',
                               [TRXDATE],
                               [JRNENTRY],
                               [ACTINDX],
							   [ORGNTSRC],
							   [ORMSTRID],
							   [ORDOCNUM],
							   [SOURCDOC],
                               SUM([DEBITAMT]) Dr,
                               SUM([CRDTAMNT]) Cr
                      FROM     GL30000 WITH (NOLOCK)
                      GROUP BY [TRXDATE] ,
                               [JRNENTRY] ,
                               [ACTINDX],
							   [ORGNTSRC],
							   [ORMSTRID],
							   [ORDOCNUM],
							   [SOURCDOC]
                     ) AS C
                      WHERE  C.ACTINDX = @AccountIndex
        ) AS X
        FULL OUTER JOIN
        ( SELECT    [GLPOSTDT] AS IVGLDATE,
                    [JRNENTRY] AS JE,
                    [IVIVINDX] AS ACCT,
					[DOCNUMBR] AS DOCNO,
					[TRXSORCE] AS TRXSOURCE,
					[DOCTYPE] AS DOCTYPE,
					[HSTMODUL] AS MODULE,
					[ORTRXSRC] AS ORIGSOURCE,
                    SUM([DEBITAMT]) AS DEBIT ,
                    SUM([CRDTAMNT]) AS CREDIT
                    FROM      ( SELECT  [GLPOSTDT] ,
                                        [JRNENTRY] ,
                                        [IVIVINDX] ,
										[DOCNUMBR],
					[TRXSORCE],
					[DOCTYPE],
					[HSTMODUL],
					[ORTRXSRC],
                                        [DEBITAMT] ,
                                        [CRDTAMNT]
                                FROM    [SEE30303]  AS M WITH (NOLOCK)
                                UNION ALL
                                SELECT  [GLPOSTDT],
                                        [JRNENTRY],
                                        [IVIVOFIX],
										[DOCNUMBR],
					[TRXSORCE],
					[DOCTYPE],
					[HSTMODUL],
					[ORTRXSRC],
                                        [CRDTAMNT],
                                        [DEBITAMT]
                                FROM  [SEE30303]   AS N WITH (NOLOCK)
                  ) AS C
                    WHERE     [IVIVINDX] = @AccountIndex AND ([CRDTAMNT]-[DEBITAMT]) &lt;&gt; 0
                    GROUP BY  [JRNENTRY],
                              [IVIVINDX],
							  [DOCNUMBR],
					[TRXSORCE],
					[DOCTYPE],
					[HSTMODUL],
					[ORTRXSRC],
                              [GLPOSTDT]
                    ) AS Y ON X.JRNENTRY = Y.JE
                    WHERE  TRXDATE BETWEEN @FROMDATE and @TODATE 
                    --( ISNULL(X.Dr, 0) - ISNULL(X.Cr, 0) &lt;&gt;
                    --ISNULL(Y.Dr, 0) - ISNULL(Y.Cr,0) )</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
