  <DataSources>
    <DataSource Name="IIC01">
      <DataSourceReference>IIC01</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>022684c5-bdcf-4e4d-acb5-075f7ed44405</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="GP">
      <Query>
        <DataSourceName>IIC01</DataSourceName>
        <CommandText>--SERIALS
SELECT A.ITEMNMBR,A.LOCNCODE,A.DATERECD,A.SERLNMBR,A.QTYTYPE,A.BIN, 1 AS QTY,
CASE WHEN A.QTYTYPE=1 THEN 'ON HAND' WHEN A.QTYTYPE=2 THEN 'RETURNED' WHEN A.QTYTYPE=3 THEN 'IN USE' WHEN A.QTYTYPE=4 THEN 'IN SERVICE' WHEN A.QTYTYPE=5 THEN 'DAMAGED' END AS ITEMSTATUS
,LEFT(A.ITEMNMBR,4) AS ITEMTYPE,A.SERLNSLD,1-SERLNSLD AS AVAIL,A.DEX_ROW_ID
FROM IV00200 A WITH (NOLOCK)</CommandText>
        <Timeout>60</Timeout>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ITEMNMBR">
          <DataField>ITEMNMBR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
