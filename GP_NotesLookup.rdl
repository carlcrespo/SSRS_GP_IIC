  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@SearchID">
            <Value>=Parameters!SearchID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        *
FROM            dbo.f_GPNotes_C(@SearchID) </CommandText>
      </Query>
      <Fields>
        <Field Name="Attachments">
          <DataField>Attachments</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Table">
          <DataField>Table</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SearchID">
          <DataField>SearchID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SearchIDField">
          <DataField>SearchIDField</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ORIGNUMB">
          <DataField>ORIGNUMB</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DocType">
          <DataField>DocType</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NOTEINDX">
          <DataField>NOTEINDX</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DocumentType">
          <DataField>DocumentType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOTEINDXHEX">
          <DataField>NOTEINDXHEX</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Link">
          <DataField>Link</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet2">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@SearchID">
            <Value>=Parameters!SearchID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
		a.Attachments
	   ,a.[Table]
      ,a.[SearchID]
	  ,ORIGNUMB
      ,IIF(a.[SearchIDField] = 'TBD' ,'',a.[SearchIDField]) AS SearchIDField
      ,a.[DocType]
	  ,CASE
		WHEN LEFT(a.[Table],3) = 'SOP' AND a.[DocType] = 1 THEN 'Quote'
		WHEN LEFT(a.[Table],3) = 'SOP' AND a.[DocType] = 2 THEN 'Order' 
		WHEN LEFT(a.[Table],3) = 'SOP' AND a.[DocType] = 3 THEN 'Invoice' 
		WHEN LEFT(a.[Table],3) = 'SOP' AND a.[DocType] = 4 THEN 'Return' 
		WHEN LEFT(a.[Table],3) = 'SOP' AND a.[DocType] = 5 THEN 'Back Order' 
		WHEN LEFT(a.[Table],3) = 'SOP' AND a.[DocType] = 5 THEN 'Fulfillment Order' 
		WHEN LEFT(a.[Table],3) != 'SOP' AND a.[DocType] = 1 THEN 'Invoice'
		WHEN LEFT(a.[Table],3) != 'SOP' AND a.[DocType] = 2 THEN 'Finance Charge' 
		WHEN LEFT(a.[Table],3) != 'SOP' AND a.[DocType] = 3 THEN 'Misc Charge' 
		WHEN LEFT(a.[Table],3) != 'SOP' AND a.[DocType] = 4 THEN 'Return' 
		WHEN LEFT(a.[Table],3) != 'SOP' AND a.[DocType] = 5 THEN 'Credit Memo' 
		WHEN LEFT(a.[Table],3) != 'SOP' AND a.[DocType] = 5 THEN 'Payment' 
		WHEN LEFT(a.[Table],3) != 'SOP' AND a.[DocType] = 0 THEN '' 
		ELSE 'UNK'
	  END DocumentType
      ,a.[NOTEINDX]
      ,a.[NOTEINDXHEX]
	  ,a.Link 
FROM
	(
	SELECT 'v10' Attachments
		  ,[Table]
		  ,[SearchIDField]
		  ,[SearchID]
		  ,ORIGNUMB
		  ,[DocType]
		  ,[NOTEINDX]
		  ,[NOTEINDXHEX]
		  ,'\\iic2\corp\Applications\GreatPlains\GP2015\Attachments\v10\' + [NOTEINDXHEX] Link
	 FROM [IIC01].[dbo].[IIC_GPV10Notes]
	 WHERE 
		 (
		 [SearchID] LIKE '%'+@SearchID+'%' 
		 OR ORIGNUMB  LIKE '%'+@SearchID+'%'
		 )
	 AND
	NOTEINDX != '0'
	AND [NOTEINDXHEX] IN
		(
		SELECT Notes_Dir 
		FROM [IIC01].[dbo].[IIC_GPV10Notes_directory]
		)
	UNION
	(
	SELECT d.Attachments
		,d.[Table]
		,d.SearchFieldID
		,d.[SearchID]
		,d.[ORIGNUMB]	
		,d.[DocType]
		,d.[NOTEINDX]
		,d.[NOTEINDXHEX]
		,d.Link
	FROM
	(			
		SELECT 
		   IIF(c.[Attachments] IS NOT NULL,c.[Attachments],'2015') Attachments
		  ,IIF(c.[Table] IS NOT NULL,c.[Table],'IIC_GPV2015Notes_directory') [Table]
		  ,IIF(c.[SearchID] IS NOT NULL,c.[SearchID],b.[SearchID])	[SearchID]	  
		  ,IIF(c.SearchIDField IS NOT NULL,c.SearchIDField,b.Type2015) SearchFieldID
		  ,ISNULL(c.[ORIGNUMB],'') [ORIGNUMB]
		  ,0 [DocType]
		  ,'' [NOTEINDX]
		  ,'' [NOTEINDXHEX]
		  ,IIF(c.[Share] IS NOT NULL,c.[Share]+c.SearchID,b.Link+b.SearchID) Link
	  FROM IIC_GPV2015Notes c
	RIGHT JOIN 
	(
		SELECT '2015' Atachments
		,[Notes_Dir] SearchID
		  ,0 [DocType]
		  ,'' [NOTEINDX]
		  ,'' [NOTEINDXHEX]
		  ,[Share] [Link]
		  ,Type2015
	  FROM [IIC01].[dbo].[IIC_GPV2015Notes_directory] 
	  ) b	ON c.SearchID = b.SearchID
	) d
	WHERE [SearchID] LIKE '%'+@SearchID+'%' OR ORIGNUMB  LIKE '%'+@SearchID+'%'
  ) 
) a</CommandText>
      </Query>
      <Fields>
        <Field Name="Attachments">
          <DataField>Attachments</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Table">
          <DataField>Table</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SearchID">
          <DataField>SearchID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ORIGNUMB">
          <DataField>ORIGNUMB</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SearchIDField">
          <DataField>SearchIDField</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DocType">
          <DataField>DocType</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DocumentType">
          <DataField>DocumentType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOTEINDX">
          <DataField>NOTEINDX</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NOTEINDXHEX">
          <DataField>NOTEINDXHEX</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Link">
          <DataField>Link</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
