  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT Rtrim([VENDORID]) Vendor_ID
      ,Rtrim([VENDNAME]) Vendor_Name
      ,Case [VENDSTTS]
		When 1 Then 'Active'
		When 2 Then 'Inactive'
		When 3 Then 'Temporary'
		Else ''
		End [Status]
      ,Rtrim([VNDCLSID]) Class_ID
      ,Rtrim([ADDRESS1]) Address1
      ,Rtrim([ADDRESS2]) Address2
      ,Rtrim([ADDRESS3]) Address3
      ,Rtrim([CITY]) City
      ,Rtrim([STATE]) [State]
      ,[ZIPCODE]
      ,[COUNTRY]
  FROM [IIC01].[dbo].[PM00200]</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
