  <DataSources>
    <DataSource Name="DataSource">
      <DataSourceReference>Dynamics</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>1c58b4c9-52ad-45a7-a78f-32ca39cb2903</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsSessionList">
      <Query>
        <DataSourceName>DataSource</DataSourceName>
        <CommandText>SELECT RTRIM(u.USERNAME) AS USERNAME,a.USERID, LOGIN = a.LOGINDAT + a.LOGINTIM, sessions.LastActivity,sessions.IdleMin, sessions.LastAction
FROM SY01400 u
INNER JOIN ACTIVITY a ON a.USERID = u.USERID 
CROSS APPLY(
	SELECT TOP 1
		RTRIM(SECDESC) AS LastAction,
		(sec.DATE1 + sec.TIME1) AS LastActivity,
		DATEDIFF(mi, CONVERT(DATETIME, sec.DATE1 + sec.TIME1), GetDate()) AS IdleMin
	FROM
		SY05000 sec
	WHERE
		sec.USERID = a.USERID
	ORDER BY
		sec.DATE1 DESC,
		sec.TIME1 DESC
) AS sessions</CommandText>
      </Query>
      <Fields>
        <Field Name="USERNAME">
          <DataField>USERNAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="USERID">
          <DataField>USERID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LOGIN">
          <DataField>LOGIN</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="LastActivity">
          <DataField>LastActivity</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="IdleMin">
          <DataField>IdleMin</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="LastAction">
          <DataField>LastAction</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
