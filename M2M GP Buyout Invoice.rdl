    <DataSource Name="DataSource1">
      <DataSourceReference>IIC01</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>47d3ae24-8594-431f-b17e-efbc95332ed9</rd:DataSourceID>
