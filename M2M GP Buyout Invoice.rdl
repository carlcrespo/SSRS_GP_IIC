  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@PostingDate1">
            <Value>=Parameters!PostingDate1.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PostingDate2">
            <Value>=Parameters!PostingDate2.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- Build 20181017
-- Work ORDER #28077

--USE IIC01
--Go

SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED 
-------------------------------------------------------------
-- test code
--DECLARE @PostingDate1 DATE, @PostingDate2 DATE 
-------------------------------------------------------------
---- Enter dates here:
--SET @PostingDate1 = '6/1/2018' --&gt; from date
--SET @PostingDate2 = '8/31/2018' --&gt; to date
-------------------------------------------------------------
;
WITH
cte_cr
AS
(
SELECT 
       "vwIIC_CommissionIFSBuyout"."XTNDPRCE", 
       "vwIIC_CommissionIFSBuyout"."ORDOCNUM" INV , 
       --"RM30201"."GLPOSTDT", 
       --"RM30201"."APFRDCNM", 
       --"vwIIC_CommissionIFSBuyout"."DEBITAMT", 
       --"GL00105"."ACTNUMST", 
       --"RM20201"."GLPOSTDT", 
       --"RM20201"."APFRDCNM", 
       --"RM30201"."ActualApplyToAmount", 
       --"RM20201"."ActualApplyToAmount", 
       --"RM30201"."APPTOAMT", 
       --"RM20201"."APPTOAMT", "RM00301"."SLPRSNFN", 
       --"RM00301"."SPRSNSLN", 
       --"vwIIC_CommissionIFSBuyout"."ACTINDX", 
       --"vwIIC_CommissionIFSBuyout"."COMMENT_4", 
       --"vwIIC_CommissionIFSBuyout"."COMMENT_3", 
       --"vwIIC_CommissionIFSBuyout"."COMMENT_2", 
       --"vwIIC_CommissionIFSBuyout"."COMMENT_1", 
       "SOP30200"."DOCAMNT", 
       "vwIIC_CommissionIFSBuyout"."ORMSTRNM" CUSTNAME, 
       "vwIIC_CommissionIFSBuyout"."TRXDATE" INV_DATE, 
       "vwIIC_CommissionIFSBuyout"."ITEMNMBR",
-----------------------------------------------------------------------------------------------------------------------------------------------
-- @TrxAmt
       /*
if isnull({RM20201.APFRDCNM}) then 
    if {RM30201.APFRDCNM} like '*CRED*' then ({vwIIC_CommissionIFSBuyout.XTNDPRCE}/-1) else 
        if {vwIIC_CommissionIFSBuyout.DEBITAMT} &lt;=0.01 then {vwIIC_CommissionIFSBuyout.XTNDPRCE} else ({vwIIC_CommissionIFSBuyout.DEBITAMT}/-1)
else
    if {RM20201.APFRDCNM} like '*CRED*' then ({vwIIC_CommissionIFSBuyout.XTNDPRCE}/-1) else 
        if {vwIIC_CommissionIFSBuyout.DEBITAMT} &lt;=0.01 then {vwIIC_CommissionIFSBuyout.XTNDPRCE} else ({vwIIC_CommissionIFSBuyout.DEBITAMT}/-1)
       */
--------------------------------------
-- test code
RM20201.APFRDCNM RM20201_APFRDCNM,
RM30201.APFRDCNM RM30201_APFRDCNM,
vwIIC_CommissionIFSBuyout.DEBITAMT,
--------------------------------------
CASE WHEN RM20201.APFRDCNM IS NULL 
THEN 
       (
    CASE WHEN RM30201.APFRDCNM like '%CRED%' 
       THEN (vwIIC_CommissionIFSBuyout.XTNDPRCE/-1) 
       ELSE 
              (
        CASE WHEN vwIIC_CommissionIFSBuyout.DEBITAMT &lt;=0.01 THEN vwIIC_CommissionIFSBuyout.XTNDPRCE 
              ELSE (vwIIC_CommissionIFSBuyout.DEBITAMT/-1)
              END )
       END )
ELSE 
       (
    CASE WHEN RM20201.APFRDCNM like '%CRED%' 
       THEN (vwIIC_CommissionIFSBuyout.XTNDPRCE/-1) 
       ELSE 
              ( 
        CASE WHEN vwIIC_CommissionIFSBuyout.DEBITAMT &lt;=0.01 THEN vwIIC_CommissionIFSBuyout.XTNDPRCE 
              ELSE vwIIC_CommissionIFSBuyout.DEBITAMT/-1
              END 
              )
       END )
END TrxAmt 
-------------------------------------------------------------------------------------------------------------------------------------------------
-- @COMMENT_1
/*
UPPERCASE(TRIM(MID({vwIIC_CommissionIFSBuyout.COMMENT_1},14,20)))
*/
,vwIIC_CommissionIFSBuyout.COMMENT_1 AS LEASE
-------------------------------------------------------------------------------------------------------------------------------------------------
-- @COMMENT_2
/*
UPPERCASE(TRIM(MID({vwIIC_CommissionIFSBuyout.COMMENT_2},29,30)))
*/
,vwIIC_CommissionIFSBuyout.COMMENT_2 AS EFF_DATE
-------------------------------------------------------------------------------------------------------------------------------------------------
-- @COMMENT_3
/*
UPPERCASE(TRIM(MID({vwIIC_CommissionIFSBuyout.COMMENT_3},19,40)))
*/
,vwIIC_CommissionIFSBuyout.COMMENT_3 AS DETAILS
-------------------------------------------------------------------------------------------------------------------------------------------------
-- @COMMENT_4
/*
UPPERCASE(TRIM(MID({vwIIC_CommissionIFSBuyout.COMMENT_4},16,40)))
*/
,vwIIC_CommissionIFSBuyout.COMMENT_4 AS [TYPE]
-------------------------------------------------------------------------------------------------------------------------------------------------
-- @ApplyFrom
/*
if isnull({RM30201.APFRDCNM}) then {RM20201.APFRDCNM} else {RM30201.APFRDCNM}
*/
,IIF(RM30201.APFRDCNM IS NULL,RM20201.APFRDCNM,RM30201.APFRDCNM) AS PAYMENT
-------------------------------------------------------------------------------------------------------------------------------------------------
-- @PAYMENT
/*
if isnull ({RM30201.APPTOAMT}) then {RM20201.APPTOAMT} else {RM30201.APPTOAMT}
*/
,IIF(RM30201.APPTOAMT IS NULL,RM20201.APPTOAMT,RM30201.APPTOAMT) AS PMT_AMT_1
-------------------------------------------------------------------------------------------------------------------------------------------------
-- @ActualApplyToAmount
,IIF(RM30201.ActualApplyToAmount IS NULL,RM20201.ActualApplyToAmount,RM30201.ActualApplyToAmount) AS PMT_AMT_2
-------------------------------------------------------------------------------------------------------------------------------------------------
-- @PostingDate
/*
if isnull({RM30201.GLPOSTDT}) then {RM20201.GLPOSTDT} else {RM30201.GLPOSTDT}
*/
,IIF(RM30201.GLPOSTDT IS NULL,RM20201.GLPOSTDT,RM30201.GLPOSTDT) AS APPLY_DATE
-------------------------------------------------------------------------------------------------------------------------------------------------
-- @Account
/*
if {vwIIC_CommissionIFSBuyout.ACTINDX} = 110 then "45220-20-106" else
    if {vwIIC_CommissionIFSBuyout.ACTINDX} = 61 then "23010-01-000" else 
        if {vwIIC_CommissionIFSBuyout.ACTINDX} = 1283 then "23015-01-000" else 
            if {vwIIC_CommissionIFSBuyout.ACTINDX} = 663 then "45250-20-106" else "Unknown"
*/
,CASE 
       WHEN vwIIC_CommissionIFSBuyout.ACTINDX = 110 
       THEN '45220-20-106' 
       ELSE 
       (
    CASE 
              WHEN vwIIC_CommissionIFSBuyout.ACTINDX = 61 
              THEN '23010-01-000' 
              ELSE
              (  
        CASE
                     WHEN vwIIC_CommissionIFSBuyout.ACTINDX = 1283 
                     THEN '23015-01-000'
                     ELSE
                     ( 
            CASE
                           WHEN vwIIC_CommissionIFSBuyout.ACTINDX = 663 
                           THEN '45250-20-106' 
                           ELSE 'Unknown'
                           END 
                     )
                     END
              )
              END
       )
       END  
    AS ACCT     
-------------------------------------------------------------------------------------------------------------------------------------------------
-- @Tolarance
/*
if ((abs({SOP30200.DOCAMNT}-{RM30201.ActualApplyToAmount})/{SOP30200.DOCAMNT}) &gt; 0.01 or {RM30201.APFRDCNM} like '*CRED*') then "Review" else "Inv Amount Matches Pmt"
*/
,IIF(
       ABS(SOP30200.DOCAMNT-RM30201.ActualApplyToAmount)/SOP30200.DOCAMNT &gt; 0.01 OR RM30201.APFRDCNM LIKE '%CRED%'
       ,'Review'
       ,'Inv Amount Matches Pmt' 
       ) AS TOLERANCE
---------------------------------------------------------------------------------------------------------------------------------------------------
-- @Salesperson
/*
{RM00301.SLPRSNFN}&amp;" "&amp;{RM00301.SPRSNSLN}
*/
,LTRIM(RTRIM(RM00301.SLPRSNFN)) + SPACE(1) + LTRIM(RTRIM(RM00301.SPRSNSLN)) AS SALESPERSON
---------------------------------------------------------------------------------------------------------------------------------------------------
FROM   {oj (((("IIC01"."dbo"."vwIIC_CommissionIFSBuyout" "vwIIC_CommissionIFSBuyout" 
 LEFT OUTER JOIN "IIC01"."dbo"."RM30201" "RM30201" ON "vwIIC_CommissionIFSBuyout"."ORDOCNUM"="RM30201"."APTODCNM") 
 LEFT OUTER JOIN "IIC01"."dbo"."SOP30200" "SOP30200" ON "vwIIC_CommissionIFSBuyout"."ORDOCNUM"="SOP30200"."SOPNUMBE") 
 LEFT OUTER JOIN "IIC01"."dbo"."RM20201" "RM20201" ON "vwIIC_CommissionIFSBuyout"."ORDOCNUM"="RM20201"."APTODCNM") 
 LEFT OUTER JOIN "IIC01"."dbo"."GL00105" "GL00105" ON "vwIIC_CommissionIFSBuyout"."ACTINDX"="GL00105"."ACTINDX") 
 LEFT OUTER JOIN "IIC01"."dbo"."RM00301" "RM00301" ON "SOP30200"."SLPRSNID"="RM00301"."SLPRSNID"}
WHERE  
 ("GL00105"."ACTNUMST"='23010-01-000' 
 OR "GL00105"."ACTNUMST"='23010-10-000' 
 OR "GL00105"."ACTNUMST"='23015-01-000' 
 OR "GL00105"."ACTNUMST"='23015-10-000' 
 OR "GL00105"."ACTNUMST"='45220-20-000' 
 OR "GL00105"."ACTNUMST"='45250-20-000')
--AND RM30201.GLPOSTDT BETWEEN @PostingDate1 AND @PostingDate2
/*
if isnull({RM30201.GLPOSTDT}) then {RM20201.GLPOSTDT} else {RM30201.GLPOSTDT}
*/
AND (IIF(RM30201.GLPOSTDT IS NULL,RM20201.GLPOSTDT,RM30201.GLPOSTDT) BETWEEN @PostingDate1 AND @PostingDate2)
--ORDER BY "vwIIC_CommissionIFSBuyout"."ORDOCNUM"
--ORDER BY "vwIIC_CommissionIFSBuyout"."ORDOCNUM"
)
SELECT
       FORMAT(cte_cr.INV_DATE,'yyyy-MM-dd') INV_DATE
       ,cte_cr.CUSTNAME
       ,cte_cr.INV
       ,cte_cr.ITEMNMBR
----------------------------------------------------
---- test code
--,cte_cr.RM20201_APFRDCNM
--,cte_cr.RM30201_APFRDCNM
--,cte_cr.DEBITAMT
--,cte_cr.XTNDPRCE 
----------------------------------------------------
       ,CONVERT(DECIMAL(10,2),cte_cr.TrxAmt) BUYOUT_AM       
       ,ISNULL(cte_cr.LEASE,'') LEASE
       ,ISNULL(cte_cr.EFF_DATE,'') EFF_DATE
       ,ISNULL(cte_cr.DETAILS,'') DETAILS
       ,ISNULL(cte_cr.[TYPE],'') [TYPE]
       ,cte_cr.PAYMENT
       ,CONVERT(DECIMAL(10,2),cte_cr.PMT_AMT_1) ApplyToAmount
       ,CONVERT(DECIMAL(10,2),cte_cr.PMT_AMT_2) ActualApplyToAmount
       ,FORMAT(cte_cr.APPLY_DATE,'yyyy-MM-dd') APPLY_DATE
       ,CONVERT(DECIMAL(10,2),cte_cr.DOCAMNT) INV_AMT
       ,cte_cr.ACCT
       ,cte_cr.TOLERANCE
       ,ISNULL(cte_cr.SALESPERSON,'') SALESPERSON
FROM cte_cr
-----------------------------------
---- test code
--WHERE cte_cr.INV LIKE 'inv21261%'
-----------------------------------
ORDER BY cte_cr.INV</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
