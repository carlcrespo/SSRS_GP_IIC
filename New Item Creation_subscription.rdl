  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>IIC01</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>110f3dee-db33-444a-b508-c1a370be1736</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>-- 20210113
SELECT
	FORMAT(CONVERT(DATE,[CREATDDT]),'MM/dd/yyyy') CreateDate,
	IIF(FORMAT(CONVERT (DATE,[MODIFDT]),'MM/dd/yyyy')='01/01/1900','',FORMAT(CONVERT (DATE,[MODIFDT]),'MM/dd/yyyy')) ModifiedDate  ,
	[ITEMNMBR] ItemNumber      ,
	[ITEMDESC] ItemDesc      ,
	[ITMSHNAM] ShortName      ,
	[ITMGEDSC] GenericDesc      ,
	[STNDCOST] StandardCost      ,
	[CURRCOST] CurrentCost      ,
	[ITMCLSCD] ItemClass      ,
	CASE [ITMTRKOP]
	WHEN 1 THEN 'No'
	WHEN 2 THEN 'Yes'
	ELSE ''
	END Serialized      ,
	[LOCNCODE] SiteID,
	DATEADD(DAY,-7,GETDATE()) minus7,
	DATEADD(DAY,-1,GETDATE()) minus1
FROM [IIC01].[dbo].[IV00101]
WHERE 
	--CREATDDT between DATEADD(DAY,-7,GETDATE()) 
	--AND DATEADD(DAY,-1,GETDATE())
	--CREATDDT = GETDATE()
	Format(CREATDDT,'yyyy-MM-dd') = Format(GETDATE() ,'yyyy-MM-dd')
	AND ITMGEDSC NOT IN ('VAR','T&amp;M','FLAT FEE')
ORDER BY    ITEMNMBR  ,ITEMDESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
