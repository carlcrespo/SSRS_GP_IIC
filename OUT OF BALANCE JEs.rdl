      <rd:DataSourceID>022684c5-bdcf-4e4d-acb5-075f7ed44405</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="GP">
      <Query>
        <DataSourceName>IIC01</DataSourceName>
        <CommandText>SELECT DISTINCT [JENumber]
      ,[RepeatSeqNumber]
      ,[TransactionDate]
      --,[EntityID]
      ,[DocumentSource]
      --,[Difference]
	  ,B.Reference,
	  B.[Account Number],
	  B.[Description],
	  B.[User Who Posted],
	  B.Series,
	  B.[Originating TRX Source],
	  B.[Originating Document Number],
	  B.[Debit Amount],
	  B.[Credit Amount]
  FROM [IIC01].[dbo].[tmc_JEsOutOfBalanceByEntity_vw] A
  INNER JOIN AccountTransactions B WITH (NOLOCK) ON A.JENumber=B.[Journal Entry] AND A.TransactionDate=B.[TRX Date] and B.Reference&lt;&gt;'Balance Brought Forward'
  WHERE B.[TRX Date] &gt; '2021-12-31'
  order by TransactionDate desc</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="JENumber">
          <DataField>JENumber</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="RepeatSeqNumber">
