        <QueryParameters>
          <QueryParameter Name="@USRDAT02">
            <Value>=Parameters!USRDAT02.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- Build 20201112
-- Shipment Tracking Report 
-- Work Orders #27923, 29066, 29067, 45738


--DECLARE @USRDAT02 DATE =    '2018-11-15'
SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED
;
WITH
cte_ship
AS
(
	SELECT        
		 o.Rep
		,o.[Doc No]
		,o.[CRM Ord No]
		,o.[Ord No]
		,o.MSTRNUMB
		,o.gp_order_id
		,o.Customer
		,o.[Cust PO No]
		,o.Carrier
		,o.Tracking
		,o.[Act Ship Date]
	FROM
	(
		SELECT        
			 a.SLPRSNID as 'Rep'
			,b.SOPNUMBE as 'Doc No'
			,o.crm_order_no 'CRM Ord No'
			,a.ORIGNUMB as 'Ord No'
			,a. MSTRNUMB
			,o.gp_order_id
			,a.CUSTNAME as 'Customer'
			,a.CSTPONBR as 'Cust PO No'
			,c.USRTAB01 as 'Carrier'
			,b.Tracking_Number as 'Tracking'
			,c.USRDAT02 as 'Act Ship Date'
		FROM  SOP10107 b
		LEFT OUTER JOIN SOP10106 c
			ON b.SOPNUMBE = c.SOPNUMBE
		INNER JOIN 
			(
				Select 
						u.SOPNUMBE
					,u.ORIGNUMB
					,U.MSTRNUMB
					,u.CUSTNAME
					,u.CUSTNMBR
					,u.SLPRSNID
					,u.CSTPONBR 
				from SOP10100 u
			UNION All
				Select 
					 p.SOPNUMBE
					,p.ORIGNUMB
					,p.MSTRNUMB
					,p.CUSTNAME
					,p.CUSTNMBR
					,p.SLPRSNID
					,p.CSTPONBR 
				from SOP30200 p
			) a 
			ON a.SOPNUMBE = b.SOPNUMBE
		FULL Join SG.dbo.Orders o
			On a.MSTRNUMB = o.gp_order_id
		WHERE 
			c.USRDAT02 =  @USRDAT02 --'11/09/2017'
			AND
            ----------------------------------------
			-- 20181218
			 --Left(b.SOPNUMBE,3) Not In ('RMA','ORD') 
			 Left(b.SOPNUMBE,3) Not In (/*'RMA',*/'ORD')
			 --------------------------------------
		--ORDER BY 
		--			a.SLPRSNID, b.SOPNUMBE
	) o
) 
,
cte_track
AS
(

SELECT 
	 RTRIM([Doc No])+'_'+RTRIM(Tracking) Track
	,COUNT([Doc No]+'_'+Tracking) cntTrack
	,[Doc No]
	,Tracking
FROM cte_ship
GROUP BY [Doc No],Tracking
)
-----------------------------------------------------------------------------
,
cte_out
AS
(
SELECT        
	 o.Rep
	,o.[Doc No]
	,ISNULL(o.[CRM Ord No],'') [CRM Ord No]
	,o.[Ord No]
	,o.MSTRNUMB
	,o.gp_order_id
	,o.Customer
	,o.[Cust PO No]
	,o.Carrier
	,o.Tracking
	,o.[Act Ship Date]
	,o.flag
FROM 
	(
	SELECT        
		 a.Rep
		,a.[Doc No]
		,a.[CRM Ord No]
		,a.[Ord No]
		,a.MSTRNUMB
		,a.gp_order_id
		,a.Customer
		,a.[Cust PO No]
		,a.Carrier
		,a.Tracking
		,a.[Act Ship Date]
		,1 flag
	FROM cte_ship a
	WHERE a.Tracking IN (SELECT cte_track.Tracking FROM cte_track WHERE cte_track.cntTrack = 1)
UNION 
	SELECT       
		 a.Rep
		,a.[Doc No]
		,a.[CRM Ord No]
		,a.[Ord No]
		,a.MSTRNUMB
		,a.gp_order_id
		,a.Customer
		,a.[Cust PO No]
		,a.Carrier
		,a.Tracking
		,a.[Act Ship Date]
		,2 flag
	FROM cte_ship a
	WHERE a.Tracking IN (SELECT cte_track.Tracking FROM cte_track WHERE cte_track.cntTrack &gt; 1)
	AND a.[CRM Ord No] IS NOT NULL 
UNION 	
	SELECT DISTINCT       
			a.Rep
		,a.[Doc No]
		,a.[CRM Ord No]
		,a.[Ord No]
		,a.MSTRNUMB
		,a.gp_order_id
		,a.Customer
		,a.[Cust PO No]
		,a.Carrier
		,a.Tracking
		,a.[Act Ship Date]
		,3 flag
	FROM cte_ship a
	WHERE a.Tracking IN (SELECT cte_track.Tracking FROM cte_track WHERE cte_track.cntTrack &gt; 1)
		AND a.[CRM Ord No] IS NULL 
		AND a.Tracking IN
		(
		SELECT       
			a.Tracking
		FROM cte_ship a
		WHERE a.Tracking IN (SELECT cte_track.Tracking FROM cte_track WHERE cte_track.cntTrack &gt; 1)
		AND a.[CRM Ord No] IS NULL 
		GROUP BY a.Tracking
		HAVING COUNT(a.Tracking) &gt; 1
		)
	) o
)
SELECT 
	 cte_out.Rep
	,cte_out.[Doc No]
	,cte_out.[CRM Ord No]
	,cte_out.[Ord No]
	,cte_out.MSTRNUMB
	,cte_out.gp_order_id
	,cte_out.Customer
	,cte_out.[Cust PO No]
	,cte_out.Carrier
	,cte_out.Tracking
	,cte_out.[Act Ship Date]
FROM cte_out
WHERE cte_out.[Doc No] IN
	(
	SELECT 
		cte_out.[Doc No]
	FROM cte_out
	GROUP BY 
		 cte_out.Rep
		,cte_out.[Doc No]
		--,cte_out.[CRM Ord No]
		,cte_out.[Ord No]
		,cte_out.MSTRNUMB
		,cte_out.gp_order_id
		,cte_out.Customer
		,cte_out.[Cust PO No]
		,cte_out.Carrier
		,cte_out.Tracking
		,cte_out.[Act Ship Date]
	HAVING COUNT(cte_out.[Doc No]) = 1
	)
UNION
SELECT 
	 cte_out.Rep
	,cte_out.[Doc No]
	,cte_out.[CRM Ord No]
	,cte_out.[Ord No]
	,cte_out.MSTRNUMB
	,cte_out.gp_order_id
	,cte_out.Customer
	,cte_out.[Cust PO No]
	,cte_out.Carrier
	,cte_out.Tracking
	,cte_out.[Act Ship Date]
FROM cte_out
WHERE cte_out.[Doc No] IN
	(
	SELECT 
		cte_out.[Doc No]
	FROM cte_out
	GROUP BY 
		 cte_out.Rep
		,cte_out.[Doc No]
		--,cte_out.[CRM Ord No]
		,cte_out.[Ord No]
		,cte_out.MSTRNUMB
		,cte_out.gp_order_id
		,cte_out.Customer
		,cte_out.[Cust PO No]
		,cte_out.Carrier
		,cte_out.Tracking
		,cte_out.[Act Ship Date]
	HAVING COUNT(cte_out.[Doc No]) &gt; 1 
	)
	AND cte_out.[CRM Ord No] &lt;&gt; ''
ORDER BY 
	cte_out.Rep, 
	cte_out.[Doc No]</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
