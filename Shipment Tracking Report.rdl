        </Field>
        <Field Name="Cust_PO_No">
          <DataField>Cust PO No</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Carrier">
          <DataField>Carrier</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Tracking">
          <DataField>Tracking</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Act_Ship_Date">
          <DataField>Act Ship Date</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
