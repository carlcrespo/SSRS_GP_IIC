    <DataSet Name="SY00800">
      <Query>
        <DataSourceName>DYNAMICS</DataSourceName>
        <CommandText>SELECT
  SY00800.WINTYPE
  ,SY00800.USERID
  ,SY00800.CMPNYNAM
  ,SY00800.BCHSOURC
  ,SY00800.BACHNUMB
  ,SY00800.POSTING
  ,SY00800.TRXSOURC
  ,SY00800.DEX_ROW_ID
FROM
  SY00800
ORDER BY SY00800.BACHNUMB,SY00800.BCHSOURC,SY00800.USERID</CommandText>
