    <DataSet Name="SY00801">
      <Query>
        <DataSourceName>GreatPlainsDYNAMICSProduction</DataSourceName>
        <CommandText>SELECT
  SY00801.RULEID
  ,SY00801.RSRCID
  ,SY00801.RSRCSBID
  ,SY00801.USERID
  ,SY00801.RSCSTATE
  ,SY00801.RSRDESC
  ,SY00801.USECT
  ,SY00801.DEX_ROW_ID
FROM
  SY00801
ORDER BY SY00801.RSRCID,SY00801.USERID</CommandText>
