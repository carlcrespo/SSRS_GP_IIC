  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@TRXDATE1">
            <Value>=Parameters!TRXDATE1.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TRXDATE2">
            <Value>=Parameters!TRXDATE2.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-------------------------------------------------------------------
---- Test code
--Declare @TRXDATE1 Date = '8/1/2016', @TRXDATE2 Date = '8/10/2016'
-------------------------------------------------------------------
-- Retired 20170223
/*
Select TOP(50) 
	 O.ORMSTRID
	,O.ORMSTRNM
	,O.DEBITAMT
From
	(
	SELECT         
			  [ORMSTRID]
			 ,[ORMSTRNM]
			 ,SUM(DEBITAMT) DEBITAMT
	  FROM [IIC01].[dbo].[GL20000]
	  where 
		ACTINDX=14
		and ORMSTRID &lt;&gt; '' 
		And TRXDATE Between @TRXDATE1 And @TRXDATE2   
	  Group By [ORMSTRID]
			  ,[ORMSTRNM]
	) O
Where O.DEBITAMT &gt; 0
Order By O.DEBITAMT DESC
*/
-------------------------------------------------------------------
-- 20170224
-- Test code
--Declare @TRXDATE1 smallDatetime = '1/1/2015', @TRXDATE2 smallDatetime = '12/31/2016'
-------------------------------------------------------------------

Select TOP(50) 
	 O.ORMSTRID
	,O.ORMSTRNM
	,sum(O.DEBITAMT) as DEBITAMT
From
	(
	SELECT         
			  [ORMSTRID]
			 ,[ORMSTRNM]
			 ,SUM(DEBITAMT) DEBITAMT
	  FROM [IIC01].[dbo].[GL20000]
	  where 
		ACTINDX in (14,3698)
		and ORMSTRID &lt;&gt; '' 
		And TRXDATE Between @TRXDATE1 And Dateadd(second,-1,Dateadd(day,1,@TRXDATE2))    
	  Group By [ORMSTRID]
			  ,[ORMSTRNM]
Union
	SELECT         
			  [ORMSTRID]
			 ,[ORMSTRNM]
			 ,SUM(DEBITAMT) DEBITAMT
	  FROM [IIC01].[dbo].[GL30000]
	  where 
		ACTINDX in (14,3698)
		and ORMSTRID &lt;&gt; '' 
		And TRXDATE Between @TRXDATE1 And Dateadd(second,-1,Dateadd(day,1,@TRXDATE2))  
	  Group By [ORMSTRID]
			  ,[ORMSTRNM]
	) O
Where O.DEBITAMT &gt; 0
Group by O.ORMSTRID ,O.ORMSTRNM
Order By sum(O.DEBITAMT) DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ORMSTRID">
          <DataField>ORMSTRID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ORMSTRNM">
          <DataField>ORMSTRNM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DEBITAMT">
          <DataField>DEBITAMT</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
